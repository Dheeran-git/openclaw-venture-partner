# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Isolation test credentials (Phase 2.5 sub-phase C)
# TEST_USER_A_EMAIL=
# TEST_USER_A_PASSWORD=
# TEST_USER_B_EMAIL=
# TEST_USER_B_PASSWORD=

# LLM providers (router picks the first healthy one in order)
COPILOT_TOKEN=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Scraping
ZYTE_API_KEY=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev   # sandbox default; swap for verified domain in prod
RESEND_TO_EMAIL=                           # verified test recipient for sandbox sends

# OpenClaw Gateway (deployed on Railway)
OPENCLAW_GATEWAY_URL=
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_ADMIN_PASSWORD=

# MCP secrets (Step 6a) — use long random strings in prod (openssl rand -hex 32)
MCP_SHARED_SECRET=        # Gateway → app (inbound skill calls)
MCP_WORKER_SECRET=        # Worker → Gateway (notifyAgent calls)

# Telegram bot (standalone webhook — NOT loaded by Gateway)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=    # openssl rand -hex 32; set when registering the webhook
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
