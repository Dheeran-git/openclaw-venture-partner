# =====================================================================
# OpenClaw Venture Partner — environment manifest
# =====================================================================
# Per PRODUCTION_BUILD_GUIDE.md §17. Required vars are unmarked; optional
# blocks have a header comment. Local: copy to .env (gitignored). Prod:
# paste each into Vercel project env (Production + Preview).
# =====================================================================

# === Application ===
NODE_ENV=development                     # production | staging | development
APP_URL=http://localhost:3000            # canonical URL, used in emails and webhooks
LOG_LEVEL=info
TZ=UTC                                   # all server times in UTC

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=                     # for verifying tokens server-side

# === Isolation test credentials (Phase 2.5 sub-phase C) ===
# TEST_USER_A_EMAIL=
# TEST_USER_A_PASSWORD=
# TEST_USER_B_EMAIL=
# TEST_USER_B_PASSWORD=

# === LLM providers (router order: copilot → gemini → groq → openrouter → anthropic-dormant) ===
COPILOT_TOKEN=                           # OAuth from dummy GitHub Pro/Student account
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=                       # leave empty to keep dormant

# === LLM behavior ===
LLM_DEFAULT_MODEL_TIER=balanced          # fast | balanced | capable
USER_DAILY_BUDGET_USD=5.00               # per-user daily LLM spend cap; 0 = unlimited

# === Scraping ===
SCRAPER=stub                             # zyte | firecrawl | stub (production must use zyte or firecrawl)
ZYTE_API_KEY=
FIRECRAWL_URL=                           # https://api.firecrawl.dev (cloud) or self-hosted URL
FIRECRAWL_API_KEY=
PAGESPEED_API_KEY=                       # Google PageSpeed Insights API key (Lighthouse proof-of-value)
# Comma-separated whitelist of sources Run Scout uses by default. Empty/unset
# = all six (upwork,linkedin,indeed,reddit,contra,freelancer). Drop sources to
# conserve Zyte free-tier quota — e.g. SCOUT_DEFAULT_SOURCES=upwork,reddit,indeed.
SCOUT_DEFAULT_SOURCES=

# === Auto-pitch fan-out (after each Run Scout) ===
# When the score-leads phase finishes, the pipeline emits pitch/draft-requested
# for the top AUTO_PITCH_MAX_PER_RUN scorers above the threshold. Caps protect
# the per-user daily LLM budget.
AUTO_PITCH_SCORE_THRESHOLD=80            # 0-100; only leads at/above this get auto-drafted
AUTO_PITCH_MAX_PER_RUN=5                 # hard cap on auto-drafts per scout run

# === Email (Resend) ===
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev  # sandbox default; swap for verified domain in prod
RESEND_TO_EMAIL=                         # verified test recipient for sandbox sends
RESEND_INBOUND_DOMAIN=                   # for inbound email parsing (post-DNS verification)

# === Inngest ===
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# === OpenClaw Gateway (deploy target: GCP e2-micro Always Free; see docs/HOSTING_GATEWAY.md) ===
OPENCLAW_GATEWAY_URL=                    # e.g. https://openclaw.your-host.duckdns.org
OPENCLAW_GATEWAY_TOKEN=                  # from /setup wizard, gates WebSocket and admin
OPENCLAW_ADMIN_PASSWORD=
# Phase 12 Stage A — Gateway-relay path for notifyAgent. Default unset = direct Telegram/Discord
# Bot API path (current, bulletproof). Set to "true" after verifying the Gateway's notify endpoint
# works on your host; on Gateway error we still fall back to direct Bot API so HITL never drops.
OPENCLAW_GATEWAY_PRIMARY=                # set to "true" after Stage B cutover
OPENCLAW_GATEWAY_NOTIFY_PATH=            # defaults to /api/notify; override if your Gateway exposes a different path

# === MCP secrets (use long random strings: openssl rand -hex 32) ===
MCP_SHARED_SECRET=                       # Gateway → /api/mcp; strict per-tool rate limits
MCP_WORKER_SECRET=                       # Worker → notifyAgent; looser limits, separate trust

# === Telegram bot (standalone webhook — NOT loaded by Gateway) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=                 # openssl rand -hex 32; set when registering the webhook
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# === Discord bot (primary alongside Telegram) ===
ENABLE_DISCORD=false                     # flip true once bot is registered + slash commands deployed
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=                      # for Ed25519 signature verification on the interactions webhook
DISCORD_APP_ID=

# === Chat platforms — scaffolded (off by default) ===
ENABLE_SLACK=false
SLACK_BOT_TOKEN=                         # xoxb-...
SLACK_SIGNING_SECRET=
SLACK_APP_ID=

ENABLE_WHATSAPP=false
WHATSAPP_PHONE_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# === Observability ===
SENTRY_DSN=
SENTRY_AUTH_TOKEN=                       # for source-map uploads in CI (optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# === Rate limiting (Upstash Redis — falls back to in-process Map if unset) ===
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
